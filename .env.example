# Copy to .env and fill in. .env is gitignored.

# --- LLM providers (Phase 3+) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Reranker (Phase 3+) ---
COHERE_API_KEY=

# --- Vector DB ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Cache / queue ---
REDIS_URL=redis://localhost:6379/0

# --- Runtime ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Feature flags ---
USE_MOCK_LLM=true
USE_MOCK_EMBEDDINGS=true
